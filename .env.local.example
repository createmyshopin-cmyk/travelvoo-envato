# Copy to .env.local — Next.js uses NEXT_PUBLIC_* (not Vite’s VITE_*).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only (API routes, scripts) — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — used by Next.js API: Marketplace AI assist (/api/saas-admin/marketplace/ai-suggest).
# Tenant "AI Search" also uses Supabase Edge Function `ai-search`; set the SAME variable name
# OPENAI_API_KEY in Supabase Dashboard → Edge Functions → Secrets (see docs/OPENAI_SETUP.md).
# OPENAI_API_KEY=
# MARKETPLACE_AI_MODEL=gpt-4o-mini
# MARKETPLACE_AI_MAX_PER_MIN=30

# Tenant marketplace checkout (Razorpay) — server-only; used by /api/marketplace/create-order & verify-payment
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# Public site origin for Instagram webhook URL in tenant Setup (HTTPS, no trailing slash).
# Used when SaaS Admin Meta OAuth redirect is empty. Should match production domain (e.g. www), not a tenant /admin URL.
# NEXT_PUBLIC_APP_URL=https://www.example.com
# Optional alias:
# NEXT_PUBLIC_WEBHOOK_PUBLIC_ORIGIN=https://www.example.com

# Meta / Instagram — platform-level; fallback if not set in SaaS Admin DB
# META_APP_ID=
# META_APP_SECRET=
# META_WEBHOOK_VERIFY_TOKEN=
# Required on the SERVER to save App Secret via SaaS Admin (encrypts saas_meta_platform_config.app_secret_encrypted).
# Use 64 hex characters (32 bytes). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# META_CREDENTIALS_ENCRYPTION_KEY=
# INSTAGRAM_OAUTH_REDIRECT_URI=https://yourdomain.com/api/integrations/instagram/callback
# INSTAGRAM_TOKEN_ENCRYPTION_KEY=   (hex, >=32 chars — encrypts tenant page tokens)
# INSTAGRAM_DM_MODEL=gpt-4o-mini
