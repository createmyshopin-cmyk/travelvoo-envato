# Same Supabase project as the Next.js app (`NEXT JS/.env.local`).
# Copy this file to `.env` in this folder and fill values from the Supabase dashboard
# or from NEXT_PUBLIC_* in `NEXT JS/.env.local`.
#
# NEXT_PUBLIC_SUPABASE_URL          → EXPO_PUBLIC_SUPABASE_URL
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY → EXPO_PUBLIC_SUPABASE_ANON_KEY
# (publishable key and anon key are the same string in Supabase.)

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key
